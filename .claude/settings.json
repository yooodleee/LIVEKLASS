{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /c/Users/dhals_zn0ga5j/python_seed/LIVEKLASS && npx tsc --noEmit 2>&1 | head -20"
          },
          {
            "type": "command",
            "command": "cd /c/Users/dhals_zn0ga5j/python_seed/LIVEKLASS && npx eslint src/ --max-warnings 0 2>&1 | tail -10"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "cd /c/Users/dhals_zn0ga5j/python_seed/LIVEKLASS && npx tsc --noEmit && npx eslint src/ --max-warnings 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /c/Users/dhals_zn0ga5j/python_seed/LIVEKLASS && bash .claude/scripts/notify-slack.sh"
          }
        ]
      }
    ]
  }
}
